    }
    .top-bars-stub { position: relative; height: 16px; }

  
    /* ══ SF2 PRESETS ══ */
    .sf2-presets {
      display: flex;
      align-items: center;
      gap: var(--sp2);
      flex-wrap: wrap;
    }
    .sf2-presets label {
