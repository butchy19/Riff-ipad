    #sf2PresetStatus.err     { color: var(--err); }

    /* ══ COMPAT iOS 12 / Safari < 14.1 ══ */
    /* Restaure les tailles fluides clamp() sur les navigateurs qui le supportent */
    @supports (font-size: clamp(1rem, 1vw, 2rem)) {
      :root {
        --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);--text-sm:clamp(.875rem,.8rem + .35vw,1rem);
        --text-base:clamp(1rem,.95rem + .25vw,1.125rem);--text-lg:clamp(1.125rem,1rem + .75vw,1.5rem);
      }
    }
    /* Fallback "gap" pour les conteneurs flex (le gap flex n'existe qu'à partir de Safari 14.1).
       Le gap des conteneurs grid fonctionne dès Safari 12, donc non concerné.
       La requête `not (inset: 0px)` cible exactement Safari < 14.1 (inset et flex-gap ont la même version). */
    @supports not (inset: 0px) {
      /* rangées horizontales */
      .sb-head  > * + *,
      .brand    > * + *,
      .mk-item  > * + *,
      .t-btns   > * + * { margin-left: var(--sp3); }
      .top-bar  > * + * { margin-left: var(--sp4); }
      .ctrl-bar > * + * { margin-left: var(--sp5); }
      .loop-row    > * + *,
      .track-acts  > * + *,
      .chords-grid > * + * { margin-left: var(--sp2); }
      .editRow  > * + * { margin-left: .4em; }
      .edBtnBar > * + * { margin-left: .3em; }
      /* colonnes verticales */
      .rec-item   > * + * { margin-top: var(--sp2); }
      .tl-wrap    > * + * { margin-top: 4px; }
      .ctrl-g     > * + * { margin-top: 5px; }
      .chord-card > * + * { margin-top: 4px; }
      .editorBody > * + * { margin-top: .5em; }
    }

  </style>
</head>
