      cursor: pointer;
      transition: border-color 0.15s;
      max-width: 180px;
    }
    #sf2PresetSelect:hover, #sf2PresetSelect:focus {
      border-color: var(--pri);
      outline: none;
    }
    #sf2PresetStatus {
      font-size: 0.70rem;
