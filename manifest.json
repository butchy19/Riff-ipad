<div id="dbg"></div>
<button id="dbgToggle">console</button>
<script>

'use strict';

/* ══ DEBUG ══ */
const dbgEl = document.getElementById('dbg');
function log(...a) {
  const d = document.createElement('div');
  d.textContent = '['+new Date().toLocaleTimeString()+'] '+a.join(' ');
  if (dbgEl) { dbgEl.appendChild(d); dbgEl.scrollTop = dbgEl.scrollHeight; }
  console.log(...a);
}
(function(){var _el=document.getElementById('dbgToggle');if(_el)_el.addEventListener('click',function(){dbgEl&&dbgEl.classList.toggle('show');});})();

/* ══ STATE ══ */
let AT = null, score = null, isPlaying = false, playerReady = false, sfCustomLoaded = false;
let playlist = [];
let currentPlaylistIdx = -1;
let currentPlaybackMs = 0;
let selectedTrackIndexes = [];

/* ══ UTILS ══ */
const $ = id => document.getElementById(id);
const fmt = ms => {
  const t = Math.max(0, Math.floor(ms/1000));
  return `${Math.floor(t/60)}:${(String(t%60).length<2?'0'+String(t%60):String(t%60))}`;
};
const esc = v => String(v).split('&').join('&amp;').split('<').join('&lt;').split('>').join('&gt;').split('"').join('&quot;').split("'").join("&#39;");

/* ══ THEME ══ */
let _theme = 'dark';
function setTheme(t) {
  _theme = t;
  document.documentElement.setAttribute('data-theme', t);
  const ic = $('themeIcon');
  if (ic) ic.innerHTML = t==='dark'
    ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'
    : '<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>';
}
function initTheme() {
  setTheme((window.matchMedia?window.matchMedia('(prefers-color-scheme: dark)').matches:false) ? 'dark' : 'light');
  (function(){var _el=document.querySelector('[data-theme-toggle]');if(_el)_el.addEventListener('click',function(){setTheme(_theme==='dark'?'light':'dark');});})();
}

/* ══ TRANSPORT UI ══ */
function setReady(ready) {
  (function(){var _e=$('playBtn');if(_e)_e.classList.toggle('inactive',!ready);})();
  (function(){var _e=$('stopBtn');if(_e)_e.classList.toggle('inactive',!ready);})();
  log('Transport', ready ? 'ACTIF' : 'inactif');
}
function syncPlayIcon() {
  const el = $('playIcon'); if (!el) return;
  el.innerHTML = isPlaying
    ? '<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>'
    : '<polygon points="5,3 19,12 5,21"/>';
}

/* ══ SOUNDFONT ══ */
const SONIVOX_URL = 'https://cdn.jsdelivr.net/npm/@coderline/alphatab@1.2.3/dist/soundfont/sonivox.sf2';
let customSFBuffer = null;

/* ══ INIT ALPHATAB ══ */
function initAlphaTab() {
  log('initAlphaTab appelé, typeof alphaTab='+typeof alphaTab);
  if (typeof alphaTab === 'undefined') { log('alphaTab undefined, retry...'); setTimeout(initAlphaTab, 200); return; }
  log('alphaTab OK, version '+(alphaTab.Environment?alphaTab.Environment.alphaTabVersion:'?'));
  try {
    AT = new alphaTab.AlphaTabApi($('alphaTab'), {
      display: { layoutMode: alphaTab.LayoutMode.Horizontal, barsPerRow: 4 },
      player: {
        enablePlayer: true, enableCursor: true, soundFont: SONIVOX_URL,
        scrollMode: (alphaTab.ScrollMode?alphaTab.ScrollMode.Continuous:2),
        scrollElement: $('scoreWrap'), scrollOffsetX: -50, scrollOffsetY: -100
      }
    });
    log('AlphaTabApi créée');
  } catch(e) { log('ERREUR init AT:', e.message); return; }

  $('sfFileInput')&&$('sfFileInput').addEventListener('change',function(e){
    const file = (e.target.files&&e.target.files[0]); if (!file) return;
    e.target.value = '';
    log('Import SF2', file.name, file.size+'b');
    const r = new FileReader();
    r.onload = ev => {
      const buf = ev.target.result;
      customSFBuffer = buf;
      const tag=$('sfTag'), lab=$('sfBtnLabel');
      if (tag) { tag.textContent='SF OK'; tag.className='sf-tag ok'; }
      if (lab) lab.textContent = file.name.replace(/\.sf2$/i, '');
      if (!AT) { log('AT pas prêt, SF2 sera appliqué au prochain init'); return; }
      try { const ok=AT.loadSoundFont(buf); log('loadSoundFont buffer, ok?', ok); } catch(e2) { log('loadSoundFont ERR:',e2.message); }
    };
    r.onerror = () => log('FileReader SF2 erreur');
    r.readAsArrayBuffer(file);
  });

  AT.scoreLoaded.on(s => {
    score = s;
    log('scoreLoaded:', s.title, s.tempo+'bpm', (s.tracks?s.tracks.length:0), 'pistes');
    if ($('scoreTitle'))  $('scoreTitle').textContent  = s.title || 'Sans titre';
    if ($('status'))      $('status').textContent      = (s.artist ? s.artist+' — ' : '')+(s.title||'fichier')+' · '+(s.tempo||120)+' bpm';
    if ($('bpmPill'))     $('bpmPill').textContent     = (s.tempo||120)+' BPM';
    isPlaying = false; syncPlayIcon();
    selectedTrackIndexes = [];
    renderTracks(); updateMetrics();
    try { if (AT && (score.tracks?score.tracks.length:0)) AT.renderTracks([score.tracks[0]]); } catch(e) { log('renderTracks init ERR:',e.message); }
    if (playerReady && (!customSFBuffer || sfCustomLoaded)) setReady(true);
    else log('Attente playerReady/SF avant activation play...');
  });

  AT.playerReady.on(() => {
    playerReady = true; log('playerReady ✓');
    if (customSFBuffer && !sfCustomLoaded) {
      sfCustomLoaded = true; log('Injection SF2 custom...');
      try { AT.loadSoundFont(customSFBuffer); } catch(e) { log('inject SF ERR:',e.message); }
      return;
    }
    const t=$('sfTag'); if (t) { t.textContent='SF ✓'; t.className='sf-tag ok'; }
    if (score) setReady(true);
  });

  AT.playerStateChanged.on(e => {
    const st = (e&&e.state!==undefined?e.state:e);
    const playing = (st===alphaTab.synth.PlayerState.Playing || st===1);
    log('playerStateChanged state='+st, 'playing='+playing);
    isPlaying = playing; syncPlayIcon();
  });

  AT.playerFinished.on(() => {
    log('playerFinished'); isPlaying=false; syncPlayIcon();
    if ($('timeline'))    $('timeline').value       = '0';
    if ($('currentTime')) $('currentTime').textContent = '0:00';
  });

  AT.playerPositionChanged.on(pos => {
    const cur = typeof pos.currentTime==='number' ? pos.currentTime : 0;
    const end = typeof pos.endTime==='number'     ? pos.endTime     : Math.max(cur,1);
    currentPlaybackMs = cur;
    const tl=$('timeline'), ct=$('currentTime'), dur=$('duration');
    if (tl)  { tl.max=String(Math.max(1,Math.floor(end/1000)));  tl.value=String(Math.floor(cur/1000)); }
    if (ct)  ct.textContent  = fmt(cur);
    if (dur) dur.textContent = fmt(end);
  });

  if (AT.soundFontLoad) {
    AT.soundFontLoad.on(e => {
      const pct = e.total>0 ? Math.round((e.loaded/e.total)*100) : 0;
      log('soundFontLoad:', pct+'%');
      if (pct>=100) { const t=$('sfTag'); if (t) { t.textContent='SF ✓'; t.className='sf-tag ok'; } }
    });
  }
  if(AT.error) AT.error.on(function(e){log('AT.error:',(e?e.message:null)||JSON.stringify(e));});
  log('Events bindés. En attente de fichier...');
}

/* ══ TRANSPORT ══ */
function handlePlay() {
  if ((function(){var _e=$('playBtn');return _e&&_e.classList.contains('inactive');})()) { log('Play bloqué : pas prêt'); return; }
  if (!AT) { log('AT null'); return; }
  try { AT.playPause(); } catch(e) { log('playPause ERR:',e.message); }
}
function handleStop() {
  if ((function(){var _e=$('stopBtn');return _e&&_e.classList.contains('inactive');})()) return;
  if (!AT) return;
  try { AT.stop(); } catch(e) { log('stop ERR:',e.message); }
  isPlaying=false; syncPlayIcon();
  if ($('timeline'))    $('timeline').value         = '0';
  if ($('currentTime')) $('currentTime').textContent = '0:00';
}

/* ══ TRACKS ══ */
function toggleTrackSelection(idx) {
  if (!(score&&score.tracks?score.tracks[idx]:null)) return;
  if (!Array.isArray(selectedTrackIndexes)) selectedTrackIndexes = [];
  const pos = selectedTrackIndexes.indexOf(idx);
  if (pos >= 0) {
    selectedTrackIndexes.splice(pos,1);
    if (!selectedTrackIndexes.length) selectedTrackIndexes = [idx];
  } else {
    selectedTrackIndexes.push(idx);
  }
  applyTrackSelection();
  document.querySelectorAll('.track-row').forEach((r,i) => {
    r.classList.toggle('active', selectedTrackIndexes.includes(i));
  });
}
function applyTrackSelection() {
  if (!AT || !(score&&score.tracks?score.tracks.length:0)) return;
  const tracksToRender = selectedTrackIndexes.map(i => score.tracks[i]).filter(Boolean);
  if (!tracksToRender.length) return;
  try {
    AT.renderTracks(tracksToRender);
    log('Pistes rendues:', tracksToRender.map(t => t.name||'Track').join(', '));
  } catch(e) { log('renderTracks multi ERR:', e.message); }
}
function renderTracks() {
  const c=$('tracksContainer'); if (!c) return;
  if (!(score&&score.tracks?score.tracks.length:0)) { c.innerHTML='<div class="empty">Charge un morceau.</div>'; return; }
  if (!Array.isArray(selectedTrackIndexes) || !selectedTrackIndexes.length) {
    selectedTrackIndexes = [0];
  }
  c.innerHTML='';
  score.tracks.forEach((tr,idx) => {
    const isOn = selectedTrackIndexes.includes(idx);
    const row=document.createElement('div');
    row.className='track-row'+(isOn?' active':'');
    row.style.cursor='pointer';
    row.innerHTML=`<div style="flex:1;min-width:0">
      <div class="track-name">${esc(tr.name||`Track ${idx+1}`)}</div>
      <div class="track-ch">Ch ${(tr.playbackInfo?tr.playbackInfo.primaryChannel:null)||'?'} · ${_trackType(tr)}</div>
    </div>`;
    row.addEventListener('click', e => {
      if (e.target.closest('.track-acts')) return;
      toggleTrackSelection(idx);
    });
    const acts=document.createElement('div'); acts.className='track-acts';
    const solo=document.createElement('button'); solo.type='button'; solo.className='btn btn-g btn-sm'; solo.textContent='S'; solo.title='Solo';
    solo.addEventListener('click', e => {
      e.stopPropagation();
      selectedTrackIndexes = [idx];
      applyTrackSelection();
      document.querySelectorAll('.track-row').forEach((r,i) => r.classList.toggle('active', i===idx));
    });
    const mute=document.createElement('button'); mute.type='button'; mute.className='btn btn-g btn-sm'; mute.textContent='M'; mute.title='Mute';
    mute.addEventListener('click', e => {
      e.stopPropagation();
      const on=mute.classList.toggle('on');
      if (AT&&(score&&score.tracks?score.tracks[idx]:null)) try { AT.changeTrackMute([score.tracks[idx]],on); } catch(err) { log('mute ERR:',err.message); }
    });
    acts.append(solo,mute); row.appendChild(acts); c.appendChild(row);
  });
  applyTrackSelection();
}
function _trackType(tr) {
  const ch=(tr.playbackInfo?tr.playbackInfo.primaryChannel:null)||-1;
  if (ch===9||ch===10) return '🥁';
  const prog=(tr.playbackInfo?tr.playbackInfo.program:-1)||-1;
  if (prog>=24&&prog<=31) return '🎸 Guitare';
  if (prog>=32&&prog<=39) return '🎸 Basse';
  if (prog>=40&&prog<=47) return '🎻 Cordes';
  if (prog>=0&&prog<=7)   return '🎹 Piano';
  return '🎵';
}
function showScore() {
  const sw = $('scoreWrap');
  if (sw) sw.style.display = 'block';
}

/* ══ PLAYLIST ══ */
function renderPlaylist() {
  const c=$('playlistContainer'); if (!c) return;
  if (!playlist.length) { c.innerHTML='<div class="empty">Aucun fichier.</div>'; return; }
  c.innerHTML='';
  playlist.forEach((it,idx) => {
    const d=document.createElement('div');
    d.className='pl-item'+(idx===currentPlaylistIdx?' active':'');
    d.innerHTML=`<div class="pl-title">${esc(it.name||it.title||'Sans titre')}</div><div class="pl-sub">${it.bpm||it.tempo||120} bpm</div>`;
    d.addEventListener('click',()=>loadFromPlaylist(idx));
    c.appendChild(d);
  });
}
function loadFromPlaylist(idx) {
  const it=playlist[idx]; if (!it) return;
  currentPlaylistIdx=idx; isPlaying=false; syncPlayIcon(); setReady(false);
  if (typeof showScore==='function') showScore();
  if (!AT) return;
  const buf=it.buf||(it.data?new Uint8Array(it.data).buffer:null);
  if (!buf) { log('Pas de buffer pour cet item'); return; }
  try { AT.load(buf); } catch(e) { log('AT.load ERR:',e.message); }
  renderPlaylist();
}

/* ══ METRICS ══ */
function updateMetrics() {
  const el=$('statusChip'); if (!el) return;
  const nbTracks=(score&&score.tracks?score.tracks.length:0)||0;
  el.textContent=`${playlist.length} fichier${playlist.length>1?'s':''} · ${nbTracks} piste${nbTracks>1?'s':''}`;
}

/* ══ BIND UI ══ */
function bindUI() {
  $('playBtn')&&$('playBtn').addEventListener('click', handlePlay);
  $('stopBtn')&&$('stopBtn').addEventListener('click', handleStop);

  $('timeline')&&$('timeline').addEventListener('input', e=>{
    if (!AT||!score) return;
    const s=Number(e.target.value||0);
    try{AT.playerPosition=s*1000;}catch(e){}
    if ($('currentTime')) $('currentTime').textContent=fmt(s*1000);
  });
  $('showAllTracksBtn')&&$('showAllTracksBtn').addEventListener('click', ()=>{
    if (!AT||!(score&&score.tracks?score.tracks.length:0)) return;
    try{AT.renderTracks(score.tracks);log('Toutes les pistes affichées');}catch(e){log('renderTracks all ERR:',e.message);}
    document.querySelectorAll('.track-row').forEach(r=>r.classList.remove('active'));
  });
  $('clearPlaylistBtn')&&$('clearPlaylistBtn').addEventListener('click', ()=>{ if(confirm('Vider ?')){playlist=[];currentPlaylistIdx=-1;renderPlaylist();updateMetrics();} });

  $('fileInput')&&$('fileInput').addEventListener('change', e=>{
    var file=(e.target.files&&e.target.files[0]);
    log('CHANGE: fichier='+(file?file.name:'null')+' size='+(file?file.size:0)+' AT='+(AT?'OK':'null'));
    if (!file) return;
    isPlaying=false; syncPlayIcon(); setReady(false);
    const reader=new FileReader();
    reader.onload=function(evt){
      e.target.value='';
      var ab=evt.target.result;
      log('Buffer='+ab.byteLength+'b, AT='+(AT?'OK':'null'));
      if (!AT) { log('AT null — alphaTab='+typeof alphaTab+' playerReady='+playerReady); return; }
      try { AT.load(ab); if(typeof showScore==='function') showScore(); log('AT.load() OK'); }
      catch(err) { log('AT.load ERR:'+err.message); }
      setTimeout(function(){
        var name=file.name.replace(/\.[^.]+$/,'');
        var tempo=(score?score.tempo:null)||120;
        playlist.push({name:name,bpm:tempo,buf:ab});
        currentPlaylistIdx=playlist.length-1;
        renderPlaylist(); updateMetrics();
      }, 1200);
    };
    reader.onerror=function(){log('READER ERR');};
    reader.readAsArrayBuffer(file);
  });
}

/* ══ INIT ══ */
function init() {
  log('=== init ===');
  initTheme();
  renderPlaylist(); updateMetrics(); syncPlayIcon();
  bindUI();
  setTimeout(initAlphaTab, 100);
}
window.addEventListener('load', () => { init(); });

/* ══ TOP BARS TOGGLE ══ */
function toggleTopBars() {
  const wrap = document.getElementById('topBarsWrap');
  const btn  = document.getElementById('topbarToggleBtn');
  const btn2 = document.getElementById('topbarToggleBtn2');
  if (!wrap) return;
  const hidden = wrap.classList.toggle('bars-hidden');
  if (btn)  btn.textContent  = hidden ? '▼ afficher' : '▲ masquer';
  if (btn2) btn2.textContent = '▼ afficher';
}

/* ══ SIDEBAR TOGGLE ══ */
function toggleSidebar() {
  const app = document.querySelector('.app');
  const btn = document.getElementById('sidebarToggleBtn');
  const icon = document.getElementById('sbToggleIcon');
  if (!app) return;
  const collapsed = app.classList.toggle('sidebar-collapsed');
  if (icon) {
    icon.setAttribute('d', collapsed ? 'M9 18l6-6-6-6' : 'M15 18l-6-6 6-6');
  }
  if (btn) {
    btn.title = collapsed ? 'Agrandir le panneau' : 'Réduire le panneau';
    btn.innerHTML = collapsed
      ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>'
      : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>';
  }
}

/* ══ SF2 PRESETS ══ */
(function() {
  const CACHE_KEY = 'sf2PresetId';

  function loadSF2FromUrl(url, label) {
    var status = document.getElementById('sf2PresetStatus');
    var sfTag  = document.getElementById('sfTag');
    var sfLab  = document.getElementById('sfBtnLabel');
    if (status) { status.textContent = 'chargement…'; status.className = 'loading'; }
    fetch(url).then(function(res){
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.arrayBuffer();
    }).then(function(buf){
      customSFBuffer = buf;
      if (sfTag) { sfTag.textContent = 'SF OK'; sfTag.className = 'sf-tag ok'; }
      if (sfLab) sfLab.textContent = label.replace(/^[^ ]+ /, '');
      if (status) { status.textContent = 'chargé'; status.className = 'ok'; setTimeout(function(){ if(status) status.textContent=''; }, 3000); }
      if (AT) {
        try { AT.loadSoundFont(buf); log('SF2 préset chargé:', label); }
        catch(e) { log('loadSoundFont err:', e.message); }
      } else {
        log('SF2 préset mis en buffer, sera appliqué au prochain init');
      }
      localStorage.setItem(CACHE_KEY, (function(){var _e=document.getElementById('sf2PresetSelect');return _e?_e.value:'';})() || '');
    }).catch(function(e){
      if (status) { status.textContent = 'erreur'; status.className = 'err'; }
      log('SF2 préset load erreur:', e.message);
    });
  }

  function onPresetChange() {
    const sel = document.getElementById('sf2PresetSelect');
    if (!sel) return;
    const opt = sel.options[sel.selectedIndex];
    const url = opt.getAttribute('data-url');
    const label = opt.text;
    if (url === '__DEFAULT__') {
      customSFBuffer = null;
      const sfTag = document.getElementById('sfTag');
      const sfLab = document.getElementById('sfBtnLabel');
      if (sfTag) { sfTag.textContent = 'SF…'; sfTag.className = 'sf-tag'; }
      if (sfLab) sfLab.textContent = 'Importer SF2';
      localStorage.removeItem(CACHE_KEY);
      log('SF2 réinitialisé au défaut Sonivox');
      return;
    }
    loadSF2FromUrl(url, label);
  }

  function restorePreset() {
    const saved = localStorage.getItem(CACHE_KEY);
    if (!saved) return;
    const sel = document.getElementById('sf2PresetSelect');
    if (!sel) return;
    for (let i = 0; i < sel.options.length; i++) {
      if (sel.options[i].value === saved) {
        sel.selectedIndex = i;
        const opt = sel.options[i];
        const url = opt.getAttribute('data-url');
        if (url && url !== '__DEFAULT__') {
          loadSF2FromUrl(url, opt.text);
        }
        break;
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const sel = document.getElementById('sf2PresetSelect');
    if (sel) sel.addEventListener('change', onPresetChange);
    restorePreset();
  });
})();

</script>
</body>
</html>
