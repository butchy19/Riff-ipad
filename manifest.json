    /* ══ TOP-BAR COMPACT & TOGGLE ══ */
    .main-col { transition: grid-template-rows 0.22s ease; }

    /* Barre fusionnée : 2 lignes denses */
    .top-bar {
      padding: var(--sp2) var(--sp4) !important;
      gap: var(--sp3) !important;
      flex-wrap: wrap;
      align-items: center;
      min-height: unset !important;
    }
    .tp-bar {
      padding: var(--sp2) var(--sp4) !important;
      gap: var(--sp3) !important;
      align-items: center;
    }
    .ctrl-bar {
      padding: var(--sp2) var(--sp4) !important;
      gap: var(--sp3) !important;
      flex-wrap: wrap;
      align-items: center;
    }
    /* Réduction du practice row */
    #practiceRow { margin-top: 2px !important; gap: var(--sp2) !important; }

    /* Bouton toggle bandeau haut */
    #topbarToggleBtn {
      position: absolute;
      right: 8px;
      bottom: -13px;
      z-index: 20;
      background: var(--pri);
      border: 1px solid #36a4af;
      border-top: none;
      border-radius: 0 0 var(--r-md) var(--r-md);
      color: #0a1a1b;
      cursor: pointer;
      padding: 2px 10px 4px;
      font-size: 0.68rem;
      font-weight: 700;
      line-height: 1.4;
      letter-spacing: .05em;
      transition: filter 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 3px 8px rgba(0,0,0,.18);
    }
    #topbarToggleBtn:hover {
      filter: brightness(1.08);
      box-shadow: 0 4px 12px rgba(0,0,0,.26);
    }

    /* Wrapper des barres du haut avec position relative */
    .top-bars-wrap {
      position: relative;
      flex: 0 0 auto;
      transition: max-height 0.22s ease, opacity 0.18s ease;
      overflow: hidden;
    }
    .top-bars-wrap.bars-hidden {
      max-height: 0 !important;
      opacity: 0;
      pointer-events: none;
    }
    /* Quand masqué, on montre juste un mini strip avec le bouton */
    .top-bars-stub {
      display: none;
      flex: 0 0 auto;
      height: 14px;
      position: relative;
    }
    .top-bars-wrap.bars-hidden ~ .top-bars-stub { display: block; }
    #topbarToggleBtn.stub-btn {
      bottom: 0;
      border-radius: var(--r-sm);
    }
    /* Score compact : hauteur max sur toute la zone restante */
    .score-wrap { flex: 1 1 0 !important; min-height: 0 !important; overflow-y: auto !important; }

  
    /* ══ SIDEBAR TOGGLE BTN ══ */
    /* Le bouton flotte sur le bord droit de la sidebar, toujours visible */
    #sidebarToggleBtn {
      position: absolute;
      top: 50%;
      right: -14px;
      transform: translateY(-50%);
      z-index: 100;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 36px;
      border-radius: 0 var(--r-md) var(--r-md) 0;
      border: 1px solid #36a4af;
      border-left: none;
      background: var(--pri);
      color: #0a1a1b;
      cursor: pointer;
      transition: filter 0.15s ease, box-shadow 0.15s ease;
      padding: 0;
      box-shadow: 2px 0 8px rgba(0,0,0,.20);
    }
    #sidebarToggleBtn:hover {
      filter: brightness(1.08);
      box-shadow: 2px 0 12px rgba(0,0,0,.28);
    }
    /* Le sb-head doit être en position relative pour ancrer le bouton */
    .sb-head { position: relative !important; }
    /* collapsed */
    .app.sidebar-collapsed {
      grid-template-columns: 14px minmax(0,1fr);
    }
    .app { transition: grid-template-columns 0.22s ease; }
    .app.sidebar-collapsed .sb-body,
    .app.sidebar-collapsed .sb-head > *:not(#sidebarToggleBtn) {
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
    .app.sidebar-collapsed .sb-head {
      padding: 0 !important;
      overflow: visible !important;
    }
    .app.sidebar-collapsed .sidebar {
      overflow: visible !important;
    }

  
    /* ══ TOP BAR TOGGLE — redesign ══ */
    #topbarToggleBtn {
