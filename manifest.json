<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta http-equiv="Content-Security-Policy" content="default-src * data: blob: filesystem:; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; worker-src * blob:; media-src * data: blob:; connect-src *; img-src * data: blob:; font-src * data:;">
  <title>Riff Room Pro</title>
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#0e1011">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Riff Room">
  <link rel="apple-touch-icon" sizes="180x180" href="icons/icon-180.png">
  <link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
  <script>
    if(typeof AudioContext==='undefined'&&typeof webkitAudioContext!=='undefined'){window.AudioContext=webkitAudioContext;}
    if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('sw.js').catch(function(e){console.warn('[SW]',e);});});}
    window.addEventListener('error',function(ev){var d=document.getElementById('dbg');if(d){var el=document.createElement('div');el.style.color='#ff6b6b';el.textContent='[ERR] '+ev.message+' L'+ev.lineno;d.appendChild(el);d.scrollTop=d.scrollHeight;}});
    window.addEventListener('unhandledrejection',function(ev){var d=document.getElementById('dbg');if(d){var el=document.createElement('div');el.style.color='#ffa500';el.textContent='[REJECT] '+(ev.reason&&ev.reason.message?ev.reason.message:String(ev.reason));d.appendChild(el);d.scrollTop=d.scrollHeight;}});
  </script>
  <style>
    html{-webkit-text-size-adjust:100%;overscroll-behavior:none;}
    *{-webkit-tap-highlight-color:transparent;}
    input:not([type=range]):not([type=checkbox]):not([type=radio]),select,textarea{font-size:16px;}
    body{padding-bottom:200px;}
  </style>
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=cabinet-grotesk@500,700,800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@coderline/alphatab@1.2.3/dist/alphaTab.min.js"></script>

  <style>
  /* Boutons compacts */
.btn.btn-sm {
  padding: 2px 6px;
  font-size: 0.78rem;
  min-height: 22px;
}

/* Boutons S / M dans la liste de pistes */
.track-acts .btn.btn-sm {
  padding: 0 6px;
  min-width: 22px;
  font-size: 0.72rem;
}

/* Boutons dans la barre principale (play, stop, loop, etc.) */
.transport .btn.btn-sm,
.controls .btn.btn-sm {
  padding: 3px 8px;
  font-size: 0.80rem;
}
    :root{
      --text-xs:.8rem;--text-sm:.95rem;
      --text-base:1.05rem;--text-lg:1.3rem;
      --sp1:.25rem;--sp2:.5rem;--sp3:.75rem;--sp4:1rem;--sp5:1.25rem;--sp6:1.5rem;
      --bg:#0e1011;--sf:#151819;--sf2:#1c2021;--sfo:#232829;--border:rgba(255,255,255,.08);
      --text:#e8efee;--muted:#7a9490;--faint:#3d5250;
      --pri:#3fbfcc;--prih:#62d0da;--prihl:rgba(63,191,204,.14);
      --ok:#5db85a;--err:#d16085;--warn:#c98744;
      --r-md:.75rem;--r-lg:1rem;--r-xl:1.25rem;--r-full:999px;
      --ease:cubic-bezier(.16,1,.3,1);
      --fd:'Cabinet Grotesk','Inter',sans-serif;--fb:'General Sans','Inter',sans-serif;
    }
    [data-theme="light"]{
      --bg:#f4f3ef;--sf:#fafaf7;--sf2:#fff;--sfo:#f0eeea;--border:rgba(0,0,0,.09);
      --text:#1a2322;--muted:#5c706d;--faint:#aebdba;
      --pri:#017f8a;--prih:#005f6a;--prihl:rgba(1,127,138,.1);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;height:100%}
    body{font-family:var(--fb);color:var(--text);background:var(--bg);height:100%;overflow:hidden}
    button,input,select{font:inherit;color:inherit}
    button{border:none;cursor:pointer;border-radius:var(--r-md);
      transition:background 160ms var(--ease),transform 140ms var(--ease),opacity 150ms}
    button:hover:not(.inactive){transform:translateY(-1px)}
    button:active:not(.inactive){transform:translateY(0)}
    input,select{border:1px solid var(--border);background:var(--sfo);border-radius:var(--r-md)}
    input[type=range]{accent-color:var(--pri);width:100%;height:4px;cursor:pointer;
      -webkit-appearance:none;appearance:none;background:var(--border);border-radius:var(--r-full);border:none;outline:none}
    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;
      border-radius:50%;background:var(--pri);cursor:pointer;box-shadow:0 0 0 3px var(--prihl)}

    .app{display:grid;grid-template-columns:290px minmax(0,1fr);height:100vh;overflow:hidden}
    .sidebar{display:flex;flex-direction:column;height:100vh;overflow:hidden;
      border-right:1px solid var(--border);background:linear-gradient(180deg,var(--sf),var(--bg))}
    .sb-head{padding:var(--sp5);border-bottom:1px solid var(--border);flex:0 0 auto;
      display:flex;align-items:center;justify-content:space-between;gap:var(--sp3)}
    .sb-body{flex:1 1 0;overflow-y:auto;padding:var(--sp4);display:grid;gap:var(--sp4);align-content:start}
    .sb-body::-webkit-scrollbar{width:3px}
    .sb-body::-webkit-scrollbar-thumb{background:var(--faint);border-radius:var(--r-full)}
    .top-bar{flex:0 0 auto;padding:var(--sp4) var(--sp6);border-bottom:1px solid var(--border);
      background:var(--sf);display:flex;justify-content:space-between;align-items:center;gap:var(--sp4)}
    .tp-bar{flex:0 0 auto;padding:var(--sp3) var(--sp6);background:var(--sf);
      border-bottom:1px solid var(--border);
      display:grid;grid-template-columns:auto 1fr auto auto;gap:var(--sp4);align-items:center}
    .ctrl-bar{flex:0 0 auto;padding:var(--sp3) var(--sp6);background:var(--sf2);
      border-bottom:1px solid var(--border);display:flex;gap:var(--sp5);flex-wrap:wrap;align-items:center}

/* ── MAIN ── */
.main {
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 0;
  overflow: hidden;
}

/* ── SCORE / TXT ── */
#scoreWrap  { display: none; }
#txtDisplay { display: none; }

#scoreWrap.visible {
  display: flex;
  flex: 1 1 0;
  min-height: 0;
  overflow-y: auto;
  padding: var(--sp5);
}

#txtDisplay.visible {
  display: flex;
  flex-direction: column;
  flex: 1 1 0;
  min-height: 0;
  overflow-y: auto;
  padding: var(--sp5);
  font-family: monospace;
}

#txtDisplay.visible > * {
  min-height: 0;
}
/* Option : une transition douce */
.score-wrap {
  transition: max-height 0.18s var(--ease);
}   .score-wrap::-webkit-scrollbar{width:6px}
    .score-wrap::-webkit-scrollbar-thumb{background:var(--faint);border-radius:var(--r-full)}

    .brand{display:flex;align-items:center;gap:var(--sp3)}
    .logo{width:36px;height:36px;border-radius:10px;display:grid;place-items:center;
      background:var(--prihl);border:1px solid rgba(63,191,204,.22);
      color:var(--pri);flex:0 0 auto}
    .brand h1{font-family:var(--fd);font-size:var(--text-lg);letter-spacing:-.03em;line-height:1}
    .brand-sub{color:var(--muted);font-size:var(--text-xs);margin-top:2px}
    .theme-btn{width:32px;height:32px;border-radius:var(--r-full);background:var(--sfo);
      border:1px solid var(--border);display:grid;place-items:center}
    .chip{display:inline-flex;align-items:center;gap:var(--sp2);padding:.35rem .7rem;
      border-radius:var(--r-full);font-size:var(--text-xs);font-weight:600;
      background:var(--prihl);border:1px solid rgba(63,191,204,.18)}
    .dot{width:7px;height:7px;border-radius:50%;flex:0 0 auto}
    .sbox{background:var(--sf2);border:1px solid var(--border);border-radius:var(--r-lg);
      padding:var(--sp4);display:grid;gap:var(--sp3)}
    .sbox h3{font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--muted)}
    .fdrop{position:relative;border:1.5px dashed rgba(63,191,204,.3);
      border-radius:var(--r-lg);padding:var(--sp4);display:flex;flex-direction:column;
      align-items:center;gap:var(--sp2);cursor:pointer;text-align:center;
      transition:border-color 160ms,background 160ms}
    .fdrop:hover{border-color:var(--pri);background:var(--prihl)}
    .fdrop input{position:absolute;top:0;right:0;bottom:0;left:0;opacity:0;cursor:pointer;width:100%;height:100%}
    .fdrop svg{color:var(--pri);opacity:.8}
    .fdrop b{font-size:var(--text-sm)}
    .fdrop span{font-size:var(--text-xs);color:var(--muted)}
    .lscroll{display:grid;gap:var(--sp2);max-height:190px;overflow-y:auto}
    .lscroll::-webkit-scrollbar{width:3px}
    .lscroll::-webkit-scrollbar-thumb{background:var(--faint);border-radius:var(--r-full)}
    .pl-item{padding:.65rem;border-radius:var(--r-md);background:var(--sfo);
      border:1px solid var(--border);cursor:pointer;transition:border-color 140ms,background 140ms}
    .pl-item:hover,.pl-item.active{border-color:var(--pri);background:var(--prihl)}
    .pl-title{font-weight:700;font-size:var(--text-sm)}
    .pl-sub{font-size:var(--text-xs);color:var(--muted);margin-top:2px}
    .mk-item{display:flex;align-items:center;gap:var(--sp3);padding:.5rem .65rem;
      border-radius:var(--r-md);background:var(--sfo);border:1px solid var(--border);
      font-size:var(--text-sm);cursor:pointer;transition:border-color 140ms}
    .mk-item:hover{border-color:var(--pri)}
    .mk-time{font-weight:700;color:var(--pri);font-size:var(--text-xs);white-space:nowrap}
    .mk-del{color:var(--err);cursor:pointer;padding:0 .3rem}
    .rec-item{display:flex;flex-direction:column;gap:var(--sp2);padding:.65rem;
      border-radius:var(--r-md);background:var(--sfo);border:1px solid var(--border)}
    .rec-item audio{width:100%;height:26px}
    .empty{color:var(--muted);font-size:var(--text-sm);text-align:center;padding:var(--sp4);
      border:1px dashed var(--border);border-radius:var(--r-md)}
    .btn{padding:.55rem .9rem;font-size:var(--text-sm);font-weight:600}
    .btn-g{background:var(--sfo);border:1px solid var(--border)}
    .btn-g:hover:not(.inactive){border-color:var(--pri);background:var(--prihl)}
    .btn-g.on{background:var(--pri)!important;color:#0a1a1b;border-color:transparent!important}
    .btn-d{background:#b05170;color:#fff}
    .btn-sm{padding:.38rem .65rem;font-size:var(--text-xs)}

    /* TRANSPORT */
    .t-btns{display:flex;align-items:center;gap:var(--sp3)}
    .btn-stop{width:42px;height:42px;display:grid;place-items:center;
      background:var(--sfo);border:1px solid var(--border);border-radius:var(--r-md)}
    .btn-play{width:52px;height:52px;display:grid;place-items:center;border-radius:var(--r-full);
      background:var(--pri);color:#0a1a1b;border:none;
      box-shadow:0 4px 16px rgba(63,191,204,.4);
      transition:background 160ms,transform 140ms,opacity 200ms,box-shadow 160ms}
    .btn-play:hover:not(.inactive){background:var(--prih)}
    /* état inactif : visuellement grisé mais JAMAIS disabled HTML */
    .btn-play.inactive{opacity:.35;cursor:not-allowed;transform:none!important;
      background:var(--sfo)!important;box-shadow:none!important;color:var(--muted)!important}
    .btn-stop.inactive{opacity:.35;cursor:not-allowed;transform:none!important}

    .tl-wrap{display:flex;flex-direction:column;gap:4px;min-width:0}
    .t-times{display:flex;justify-content:space-between;font-size:var(--text-xs);color:var(--muted)}
    .loop-row{display:flex;gap:var(--sp2);align-items:center}
    .loop-lbl{font-size:var(--text-xs);color:var(--muted);white-space:nowrap}
    .ctrl-g{display:flex;flex-direction:column;gap:5px;min-width:105px}
    .ctrl-lbl{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
      color:var(--muted);display:flex;justify-content:space-between}
    .ctrl-v{color:var(--text);font-weight:700}
    .ctrl-sep{width:1px;background:var(--border);align-self:stretch}
    .sel-sm{padding:.35rem .5rem;font-size:var(--text-xs);width:100%}
/* Conteneur de la liste de pistes */
#tracksContainer {
  font-size: 0.8rem;
}

/* Ligne de piste */
.track-row {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 6px;
  border-radius: 4px;
  margin-bottom: 2px;
  background: transparent;
  transition: background 0.1s ease, transform 0.05s ease;
}

/* Zébrage léger */
.track-row:nth-child(2n) {
  background: rgba(255,255,255,0.02);
}

/* Survol */
.track-row:hover {
  background: rgba(255,255,255,0.05);
}

/* Piste sélectionnée */
.track-row.active {
  background: rgba(63,191,204,0.18);
}

/* Nom piste / info canal */
.track-name {
  font-weight: 600;
  margin-bottom: 1px;
}
.track-ch {
  font-size: 0.70rem;
  color: var(--muted);
}

/* Colonne actions à droite */
.track-acts {
  display: flex;
  gap: 4px;
  align-items: center;
}
      border-radius:var(--r-md);background:var(--sfo);border:1px solid var(--border);
      transition:border-color 140ms,background 140ms}
    .track-row:hover{border-color:rgba(63,191,204,.4);background:#25292b}
    .track-row.active{border-color:var(--pri);background:var(--prihl)}
    .track-row.active .track-name{color:var(--pri)}
    .track-name{flex:1;font-size:var(--text-sm);font-weight:600;overflow:hidden;
      text-overflow:ellipsis;white-space:nowrap}
    .track-ch{font-size:10px;color:var(--muted)}
    .track-acts{display:flex;gap:var(--sp2)}
    #alphaTab{min-height:460px;border-radius:var(--r-xl);padding:var(--sp4);
      background:rgba(28,32,33,.8);border:1px solid var(--border)}
    .rec-chip{display:inline-flex;align-items:center;gap:var(--sp2);padding:.32rem .7rem;
      border-radius:var(--r-full);font-size:var(--text-xs);font-weight:700;
      border:1px solid rgba(201,135,68,.3);
      background:#322e28}
    .rec-chip.active{background:#3b2f33;
      border-color:rgba(209,96,133,.35);animation:pulse 1s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
    .sf-tag{padding:.28rem .6rem;border-radius:var(--r-full);font-size:10px;font-weight:700;
      letter-spacing:.05em;background:var(--sfo);border:1px solid var(--border);color:var(--muted)}
    .sf-tag.ok{border-color:rgba(93,184,90,.4);
      color:var(--ok);background:#28302a}
    .sf-tag.err{border-color:rgba(209,96,133,.4);color:var(--err)}
    /* console */
    #dbg{position:fixed;bottom:34px;left:0;right:0;max-height:130px;overflow-y:auto;
      background:rgba(0,0,0,.92);border-top:1px solid rgba(255,255,255,.1);
      font-size:11px;font-family:monospace;padding:var(--sp2) var(--sp4);
      color:#a8e6a0;z-index:9999;display:block;min-height:80px}
    #dbg.show{display:block}
    #dbgToggle{position:fixed;bottom:var(--sp2);right:var(--sp2);z-index:9999;
      padding:.28rem .55rem;font-size:10px;background:rgba(0,0,0,.7);
      border:1px solid var(--border);color:var(--muted);border-radius:var(--r-md);cursor:pointer}
    /* ── CURSEUR ALPHATAB ── */
    /* alphaTab injecte ces classes dans le DOM du score */
    .at-cursor-bar{
      background:rgba(63,191,204,.18)!important;
      border-left:2px solid var(--pri)!important;
      border-radius:4px!important;
      animation:at-bar-fade .15s ease!important}
    @keyframes at-bar-fade{from{opacity:0;transform:scaleX(.85)}to{opacity:1;transform:scaleX(1)}}

    .at-cursor-beat{
      background:#5cc9d4!important;
      width:2.5px!important;
      border-radius:2px!important;
      opacity:.92!important}

    .at-highlight *{
      fill:var(--pri)!important;
      stroke:var(--pri)!important}

    /* note active : halo coloré */
    .at-note-cursor{
      background:rgba(63,191,204,.3)!important;
      border-radius:50%!important;
      animation:note-pop .12s ease!important}
    @keyframes note-pop{from{transform:scale(.6);opacity:0}to{transform:scale(1);opacity:1}}

    /* zone de défilement : pas d'overflow-x caché pour que le scroll suive */
    #alphaTab{overflow:visible!important}
    .at-surface{overflow:visible!important}

    /* ── DÉCOMPTE OVERLAY ── */
    #countdownOverlay{
      position:fixed;top:0;right:0;bottom:0;left:0;z-index:8888;
      display:none;align-items:center;justify-content:center;
      background:rgba(0,0,0,.72);-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px)}
    #countdownOverlay.show{display:flex}
    .cd-circle{
      width:160px;height:160px;border-radius:50%;
      border:4px solid var(--pri);
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      background:rgba(14,16,17,.9);
      box-shadow:0 0 48px rgba(63,191,204,.35);
      animation:cd-pulse 1s ease-in-out infinite}
    @keyframes cd-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
    .cd-number{font-family:var(--fd);font-size:5rem;font-weight:800;
      color:var(--pri);line-height:1;letter-spacing:-.04em}
    .cd-label{font-size:var(--text-xs);color:var(--muted);margin-top:.4rem;letter-spacing:.08em;text-transform:uppercase}
    .cd-cancel{margin-top:var(--sp5);padding:.45rem 1.1rem;
      background:var(--sfo);border:1px solid var(--border);
      border-radius:var(--r-full);font-size:var(--text-sm);font-weight:600;color:var(--muted);cursor:pointer}
    .cd-cancel:hover{border-color:var(--err);color:var(--err)}
    /* bouton décompte dans transport */
    .btn-cd{width:36px;height:36px;display:grid;place-items:center;font-size:11px;font-weight:800;
      background:var(--sfo);border:1px solid var(--border);border-radius:var(--r-md);color:var(--muted)}
    .btn-cd:hover:not(.inactive){border-color:var(--pri);color:var(--pri)}
    .btn-cd.on{background:var(--prihl);border-color:var(--pri);color:var(--pri)}

    .chords-grid{display:flex;flex-wrap:wrap;gap:var(--sp2)}
    .chord-card{background:var(--sf2);border:1px solid var(--border);
      border-radius:var(--r-md);padding:var(--sp2) var(--sp3);
      display:flex;flex-direction:column;align-items:center;gap:4px}
    .chord-card:hover{border-color:var(--pri)}
    .chord-name{font-family:var(--fd);font-size:.9rem;font-weight:800;color:var(--pri)}
    .chord-fingers{font-size:9px;color:var(--muted)}
    .chords-empty{font-size:var(--text-xs);color:var(--muted);text-align:center;padding:var(--sp3)}

@media(max-width:900px){
  body{overflow:auto}
  .app{grid-template-columns:1fr;height:auto;overflow:visible}
  .sidebar{height:auto;overflow:visible}
  .sb-body{overflow:visible;height:auto;max-height:none}
  .tp-bar{grid-template-columns:auto 1fr}
}	/* === POPUP ACCORDS v16 === */
#chordsPopup, #chordsPopup.show { display: block; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.9); width: 720px; max-width: 92vw; max-height: 82vh; background: #0d0f1f; border: 1px solid #ffffff18; border-radius: 10px; z-index: 10005; box-shadow: 0 12px 40px #0008, 0 0 0 9999px rgba(13,15,31,0.7); opacity: 0; pointer-events: none; transition: 0.18s cubic-bezier(0.2, 0.8, 0.2, 1); }
#chordsPopup.show { transform: translate(-50%, -50%) scale(1); opacity: 1; pointer-events: all; }
.chordsPopupHead { display: flex; align-items: center; justify-content: space-between; padding: 0.55em 0.7em; border-bottom: 1px solid #ffffff15; background: #101228; border-radius: 10px 10px 0 0; }
.chordsTitle { font-weight: 700; font-size: 16px; color: #c88; letter-spacing: 0.5px; }
.chordsPopupHead .closePill { background: none; border: none; color: #666; cursor: pointer; font-size: 18px; border-radius: 4px; padding: 0.2em 0.5em; }
.chordsPopupHead .closePill:hover { background: #ffffff08; color: #f44; }
.chordsPopupHead .addNewBtn { background: linear-gradient(135deg, #2a582a, #3a883a); border: none; border-radius: 4px; color: #7f7; cursor: pointer; font-size: 13px; padding: 0.25em 0.6em; }
.chordsPopupHead .addNewBtn:hover { background: #3a883a; color: #fff; }
.chordsPopupBody { padding: 0.6em; overflow-y: auto; max-height: calc(82vh - 46px); }
.chordPopupGrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.45em; }
.chordCardP { background: #ffffff06; border-radius: 6px; padding: 0.5em; cursor: pointer; position: relative; transition: 0.12s; border: 1px solid transparent; }
.chordCardP:hover { background: #ffffff0f; border-color: #3a58cf; }
.chordNameP { font-weight: 700; font-size: 13px; margin-bottom: 0.1em; color: #a8b8ff; }
.chordDiagramP { background: #1a1a2e; border-radius: 4px; }
.editBtnP { position: absolute; top: 4px; right: 4px; background: #ffffff18; border: none; border-radius: 4px; width: 20px; height: 20px; color: #aaf; cursor: pointer; font-size: 11px; opacity: 0; transition: 0.1s; display: flex; align-items: center; justify-content: center; }
.chord-card { position: relative; }

.chord-card .editBtnP {
  position: absolute;
  top: 4px;
  right: 4px;
